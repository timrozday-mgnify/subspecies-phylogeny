// Stage 4 — Final phylogeny
//
// Copy the Gubbins settings finalised in stage 3, then add IQ-TREE bootstrap
// and model arguments for the final trees.
//
// Pass with: nextflow run main.nf -c examples/stage4_final/modules.config \
//                                 -params-file examples/stage4_final/params.yml

process {
    withName: 'SKA2_ALIGN' {
        ext.args = { "--min-freq ${meta.min_freq} --filter no-filter" }
    }

    // -----------------------------------------------------------------------
    // Gubbins — copy finalised settings from stage 3
    // -----------------------------------------------------------------------
    // (copy ext.args from examples/stage3_trial/modules.config)
    withName: 'GUBBINS' {
        ext.args = [
            '--tree-builder fasttree',
            '--iterations 5',
            '--min-snps 3',
            '--min-window-size 100',
            '--filter-percentage 25.0',
            '--model GTRGAMMA',
        ].join(' ')
    }

    // -----------------------------------------------------------------------
    // IQ-TREE — maximum-likelihood phylogeny
    // -----------------------------------------------------------------------
    // Key arguments:
    //   -fconst A,C,G,T
    //     Constant-site counts for ascertainment-bias correction. The pipeline
    //     supplies these automatically on the no_gubbins track via
    //     meta.constant_sites. Always keep this expression; do not replace it
    //     with a literal value.
    //   -m <model>
    //     Substitution model.
    //     MFP        ModelFinder selects the best model (default; slowest)
    //     GTR+G      general time-reversible + gamma-distributed rates; good
    //                all-round choice for bacterial SNP alignments
    //     GTR+G+ASC  GTR+G with ascertainment-bias correction — do NOT use on
    //                the no_gubbins track; the pipeline already applies -fconst
    //                for that correction there. Safe on the gubbins track but
    //                the pipeline does not apply it automatically.
    //   -B <n>
    //     Ultrafast bootstrap replicates. 1000 is standard. Adds support
    //     values to all branches in the treefile.
    //   -b <n>
    //     Standard (non-parametric) bootstrap. Much slower than -B; use only
    //     if reviewers or downstream tools require it.
    //   --seed <n>
    //     Fix the random seed for reproducibility.
    //   -T <n|AUTO>
    //     Threads. Leave as AUTO to let IQ-TREE decide based on alignment size,
    //     or set explicitly to match the process cpus directive.
    withName: 'IQTREE' {
        ext.args = {
            [
                meta.constant_sites ? "-fconst ${meta.constant_sites}" : '',
                '-m GTR+G',
                '-B 1000',
                '--seed 42',
            ].findAll { it }.join(' ')
        }
    }
}
