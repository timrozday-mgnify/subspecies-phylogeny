// Stage 2 — optional tool-argument overrides
//
// This file is only needed if you want to change tool defaults. Most stage 2
// runs work fine with no custom modules.config.
//
// Pass with: nextflow run main.nf -c examples/stage2_explore/modules.config \
//                                 -params-file examples/stage2_explore/params.yml

process {
    // ska align: the pipeline always adds --min-freq from params.ska_align_min_freq.
    // Add extra flags here if needed.
    withName: 'SKA2_ALIGN' {
        // --filter no-filter: include positions present in any subset of samples
        //   (default is 'core', requiring presence in all samples)
        // --filter bi-allelic: restrict to positions with exactly two alleles
        ext.args = { "--min-freq ${meta.min_freq} --filter no-filter" }
    }

    withName: 'GUBBINS' {
        ext.args = [
            '--tree-builder iqtree-fast',
            '--iterations 5',
            '--min-snps 3',
            '--min-window-size 100',
            '--filter-percentage 100',
            '--model GTRGAMMA',
        ].join(' ')
    }
}
