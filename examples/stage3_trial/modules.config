// Stage 3 — Gubbins parameter trialling
//
// Adjust the values below and re-run stage 3 until the recombination
// predictions and filtered alignments look reasonable, then copy the
// final values into examples/stage4_final/modules.config.
//
// Pass with: nextflow run main.nf -c examples/stage3_trial/modules.config \
//                                 -params-file examples/stage3_trial/params.yml

process {
    // -----------------------------------------------------------------------
    // ska align — additional flags beyond --min-freq (set by the pipeline)
    // -----------------------------------------------------------------------
    withName: 'SKA2_ALIGN' {
        ext.args = { "--min-freq ${meta.min_freq} --filter no-filter" }
    }

    // -----------------------------------------------------------------------
    // Gubbins — recombination detection
    // -----------------------------------------------------------------------
    // Key arguments:
    //   --tree-builder <builder>
    //     fasttree   fast, works with as few as 3 samples (pipeline default)
    //     raxmlng    more accurate ML tree; requires ≥4 samples
    //     iqtree     slower but thorough; requires ≥4 samples
    //     rapidnj    neighbour-joining; very fast first-pass for large datasets
    //   --iterations <n>
    //     Number of Gubbins iterations. More iterations refine boundaries but
    //     increase runtime. 5 is usually sufficient.
    //   --min-snps <n>
    //     Minimum SNPs required to call a recombination event. Increase (e.g.
    //     10–20) to reduce false positives in very similar genomes where many
    //     small "recombination" blocks may be noise.
    //   --min-window-size <bp>
    //     Minimum length of a recombination block. Increase to ignore very
    //     short predicted blocks.
    //   --filter-percentage <pct>
    //     Sequences with more than pct% of bases masked are dropped from
    //     recombination detection. Reduce if many samples are being excluded.
    //   --model <model>
    //     Substitution model: GTRGAMMA (default), GTR, HKY, JC.
    withName: 'GUBBINS' {
        ext.args = [
            '--tree-builder iqtree-fast',
            '--iterations 5',
            '--min-snps 3',
            '--min-window-size 100',
            '--filter-percentage 25.0',
            '--model GTRGAMMA',
        ].join(' ')
    }
}
