params {
    // Required
    input            = null
    outdir           = './results'

    // Publishing
    publish_dir_mode = 'copy'

    // SKA2
    ska_k              = 31
    ska_align_min_freq = '0.9'  // comma-separated list of --min-freq values for ska align (e.g. '0.5,0.9,1.0')
    skip_alignment     = false  // skip ska align and all downstream steps; produces only merged SKF + FastANI outputs
    skip_iqtree        = false  // skip IQ-TREE; useful when trialling weed/gubbins parameters before committing to tree inference
    ska_merged_skf     = null   // path to a pre-computed merged.skf; skips build/merge/fastani when set
    ska_delete_samples = null   // path to newline-delimited file of sample names to remove from the merged SKF
    ska_distance       = false  // run ska distance (pairwise SNP distances) on the merged SKF
    ska_lo             = false  // run ska lo (left-out SNP/INDEL detection) on the merged SKF
    ska_lo_reference   = null   // optional reference FASTA for ska lo coordinate anchoring

    // MultiQC
    multiqc_title    = null

    // Resource limits (overridden by HPC/cloud profiles)
    max_cpus         = 16
    max_memory       = '128.GB'
    max_time         = '240.h'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    conda {
        conda.enabled = true
    }
}

manifest {
    name            = 'subspecies-phylogeny'
    description     = 'Whole-genome SNP phylogeny of within-species bacterial genomes using SKA2'
    version         = '0.1.0'
    nextflowVersion = '>=25.0'
}
