nextflow_process {
    name "Test Process SKA2_ALIGN"
    script "../main.nf"
    process "SKA2_ALIGN"

    tag "modules"
    tag "ska2"
    tag "ska2/align"
    tag "ska2/build"
    tag "ska2/merge"

    test("merged SKF from two Bacteroides uniformis genomes") {
        setup {
            run("SKA2_BUILD", alias: "BUILD_1") {
                script "../../build/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'BU_61' ],
                        file(params.test_data_base + 'BU_61_NT5381.1.fa', checkIfExists: true)
                    ]
                    """
                }
            }
            run("SKA2_BUILD", alias: "BUILD_2") {
                script "../../build/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'BU_909' ],
                        file(params.test_data_base + 'BU_909_NT5401.1.fa', checkIfExists: true)
                    ]
                    """
                }
            }
            run("SKA2_MERGE") {
                script "../../merge/main.nf"
                process {
                    """
                    input[0] = BUILD_1.out.skf.mix(BUILD_2.out.skf)
                        .map { meta, skf -> skf }
                        .collect()
                    """
                }
            }
        }
        when {
            process {
                """
                input[0] = SKA2_MERGE.out.skf.map { skf -> [ [ id:'test', min_freq:'0.9' ], skf ] }
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.alignment.size() == 1 },
                { assert path(process.out.alignment.get(0)[1]).exists() },
                // alignment FASTA must contain one entry per input sample
                { assert path(process.out.alignment.get(0)[1]).readLines().count { it.startsWith('>') } == 2 },
                { assert snapshot(
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }
    }

    test("merged SKF from two B. uniformis genomes - stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [ [ id:'test', min_freq:'0.9' ], file('stub.skf') ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }
    }
}
