# Local modifications to the nf-core/snpsites module
#
# Upstream source: https://github.com/nf-core/modules/blob/master/modules/nf-core/snpsites/main.nf
#
# Changes vs upstream:
#   1. Added val(meta) to input and all output tuples so that per-branch
#      metadata (weed label, min_freq) is carried through the channel. The
#      upstream module is meta-free and produces a single output stream;
#      this pipeline fans out over multiple (weed × min_freq) combinations
#      in parallel, requiring meta to keep branches distinct and to allow
#      .join() operations downstream.
#   2. Output files are named via task.ext.prefix (defaulting to meta.id)
#      instead of hardcoded 'filtered_alignment.fas' / 'constant.sites.txt'.
#      With multiple parallel branches each branch would otherwise overwrite
#      the same filename in the work directory.
#   3. Removed the env 'CONSTANT_SITES' output. Constant-site counts are
#      written to a file (${prefix}.sites.txt) and read in the workflow with
#      .text.trim() to populate meta.constant_sites for the IQ-TREE ext.args
#      closure. The env channel mechanism is not used because it does not
#      compose cleanly with channel joins on meta.
#   4. stub block updated to match the new output filenames.

--- a/modules/nf-core/snpsites/main.nf
+++ b/modules/nf-core/snpsites/main.nf
@@ -1,4 +1,5 @@
 process SNPSITES {
+    tag "$meta.id"
     label 'process_medium'
 
     conda "${moduleDir}/environment.yml"
@@ -7,44 +8,42 @@
         'quay.io/biocontainers/snp-sites:2.5.1--hed695b0_0' }"
 
     input:
-    path alignment
+    tuple val(meta), path(alignment)
 
     output:
-    path "*.fas"        , emit: fasta
-    path "*.sites.txt"  , emit: constant_sites
-    path "versions.yml" , emit: versions
-    env 'CONSTANT_SITES', emit: constant_sites_string
+    tuple val(meta), path("*.fas"),        emit: fasta
+    tuple val(meta), path("*.sites.txt"),  emit: constant_sites
+    path "versions.yml",                   emit: versions
 
     when:
     task.ext.when == null || task.ext.when
 
     script:
-    def args = task.ext.args ?: ''
+    def args   = task.ext.args   ?: ''
+    def prefix = task.ext.prefix ?: "${meta.id}"
     """
     snp-sites \\
         $alignment \\
         $args \\
-        > filtered_alignment.fas
+        > ${prefix}.fas
 
-    echo \$(snp-sites -C $alignment) > constant.sites.txt
+    snp-sites -C $alignment > ${prefix}.sites.txt
 
-    export CONSTANT_SITES=\$(cat constant.sites.txt)
-
     cat <<-END_VERSIONS > versions.yml
     "${task.process}":
         snpsites: \$(snp-sites -V 2>&1 | sed 's/snp-sites //')
     END_VERSIONS
     """
+
     stub:
+    def prefix = task.ext.prefix ?: "${meta.id}"
     """
-    touch filtered_alignment.fas
-    touch constant.sites.txt
-    export CONSTANT_SITES=\$(cat constant.sites.txt)
+    touch ${prefix}.fas
+    echo '0,0,0,0' > ${prefix}.sites.txt
 
     cat <<-END_VERSIONS > versions.yml
     "${task.process}":
         snpsites: \$(snp-sites -V 2>&1 | sed 's/snp-sites //')
     END_VERSIONS
     """
-
 }
