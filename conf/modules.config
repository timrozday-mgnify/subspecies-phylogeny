// Default: don't publish anything (modules must opt in explicitly below)
process {
    publishDir = [ enabled: false ]

    withName: 'NJ_TREE_FASTANI' {
        ext.args   = '--format fastani'
        ext.prefix = 'fastani_nj'
        publishDir = [
            path: { "${params.outdir}/nj_tree" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'NJ_TREE_SKA2' {
        ext.args   = '--format ska2'
        ext.prefix = 'ska2_distance_nj'
        publishDir = [
            path: { "${params.outdir}/nj_tree" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'FASTANI_ALLVSALL' {
        publishDir = [
            path: { "${params.outdir}/fastani" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKA2_BUILD' {
        // k-mer size passed explicitly so it appears in pipeline provenance
        ext.args = { "-k ${params.ska_k}" }
        publishDir = [
            path: { "${params.outdir}/ska2/skf" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKA2_MERGE' {
        // merged.skf is published because it can be reused for re-alignment with
        // different ska align options without rebuilding all samples
        publishDir = [
            path: { "${params.outdir}/ska2" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKA2_DELETE' {
        ext.prefix = 'merged_deleted'
        publishDir = [
            path: { "${params.outdir}/ska2" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKA2_DISTANCE' {
        ext.prefix = 'distances'
        publishDir = [
            path: { "${params.outdir}/ska2" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKA2_LO' {
        ext.prefix = 'lo_output'
        publishDir = [
            path: { "${params.outdir}/ska2" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKA2_ALIGN' {
        ext.args   = { "--min-freq ${meta.min_freq}" }
        publishDir = [
            path: { "${params.outdir}/ska2/min_freq_${meta.min_freq}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SNPSITES' {
        publishDir = [
            path: { "${params.outdir}/snpsites/min_freq_${meta.min_freq}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'GUBBINS' {
        ext.args   = '--tree-builder fasttree'
        // Start below process_medium's 6×attempt so task.cpus matches actual
        // usage after the nproc cap in the script (avoids idle allocated CPUs).
        cpus       = { Math.min(task.attempt * 4, params.max_cpus as int) }
        publishDir = [
            path: { "${params.outdir}/gubbins/min_freq_${meta.min_freq}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'IQTREE' {
        // Ascertainment bias correction: -fconst informs IQ-TREE of constant sites
        // stripped by snp-sites so branch lengths are correctly estimated.
        // When Gubbins is used, constant_sites is absent from meta (Gubbins already
        // strips variable sites) so the correction is omitted.
        ext.args   = { meta.constant_sites ? "-fconst ${meta.constant_sites}" : '' }
        ext.prefix = 'tree'
        publishDir = [
            path: { "${params.outdir}/iqtree/${meta.gubbins}/min_freq_${meta.min_freq}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }
}
